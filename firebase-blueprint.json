{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and financial standing",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "trader", "sme", "admin"] },
        "walletBalance": { "type": "number" },
        "currency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "assistant"] },
              "content": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "messages"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal", "transfer", "fx_lock"] },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "provider": { "type": "string", "enum": ["flutterwave", "ecobank", "wio"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "status"]
    },
    "KYC": {
      "title": "KYC",
      "description": "Know Your Customer documents and verification status",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["individual", "company"] },
        "selfieUrl": { "type": "string" },
        "idPhotoUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "companyInfo": {
          "type": "object",
          "properties": {
            "directorName": { "type": "string" },
            "whatsappNumber": { "type": "string" },
            "registrationFormUrl": { "type": "string" },
            "tin": { "type": "string" },
            "region": { "type": "string" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "Chat",
      "description": "User conversation history"
    },
    "/users/{userId}/transactions/{txId}": {
      "schema": "Transaction",
      "description": "User financial transactions"
    },
    "/users/{userId}/kyc/data": {
      "schema": "KYC",
      "description": "User KYC data"
    }
  }
}
